# =============================================================================
# AI-Powered Personalised Education Platform — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values before running the app.
# NEVER commit your actual `.env` file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string.
# Format: postgresql://user:password@host:port/dbname
# The backend will exit with a non-zero status code at startup if this is missing.
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/edu_platform

# -----------------------------------------------------------------------------
# JWT (JSON Web Token)
# -----------------------------------------------------------------------------
# Secret key used to sign and verify JWT access and refresh tokens.
# Use a long, random, high-entropy string — e.g. generate with:
#   python -c "import secrets; print(secrets.token_hex(64))"
# The backend will exit with a non-zero status code at startup if this is missing.
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# -----------------------------------------------------------------------------
# Google Generative AI (Gemini)
# -----------------------------------------------------------------------------
# API key for the Gemini generative language API.
# Obtain from: https://console.cloud.google.com → APIs & Services → Credentials
# Ensure the "Generative Language API" is enabled in your Google Cloud project.
# The backend will exit with a non-zero status code at startup if this is missing.
GEMINI_API_KEY=your-gemini-api-key-here

# Name of the Gemini model to use for content generation and quiz questions.
# Default: gemma-4-31b-it  (change only if you want to test a different model)
GEMINI_MODEL_NAME=gemma-4-31b-it

# -----------------------------------------------------------------------------
# YouTube Data API
# -----------------------------------------------------------------------------
# API key for the YouTube Data API v3.
# Obtain from: https://console.cloud.google.com → APIs & Services → Credentials
# Ensure the "YouTube Data API v3" is enabled in your Google Cloud project.
# The backend will exit with a non-zero status code at startup if this is missing.
YOUTUBE_API_KEY=your-youtube-api-key-here

# -----------------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------------
# Secret key used by Flask to sign session cookies (distinct from JWT secret).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-flask-secret-key-change-this

# Runtime environment — controls debug mode, error verbosity, etc.
# Valid values: development | production
FLASK_ENV=development

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed cross-origin request origins.
# In development this is typically the Vite dev server.
# In production set this to the exact frontend domain (e.g. https://app.example.com).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
